# SkinTwin Salon Environment Variables
# Copy this file to .env.development for local development

# =============================================================================
# PAYSTACK CONFIGURATION
# =============================================================================
# Paystack authentication key for API calls
GATSBY_AUTH_KEY=your_paystack_secret_key_here

# Paystack base API URL
GATSBY_BASE_API=https://api.paystack.co

# Terminal ID for payment terminal integration
GATSBY_TERMINAL_ID=your_terminal_id

# =============================================================================
# PUSHER CONFIGURATION (Real-time payment status updates)
# =============================================================================
GATSBY_PUSHER_KEY=your_pusher_key
GATSBY_PUSHER_APP_ID=your_app_id
GATSBY_PUSHER_SECRET=your_pusher_secret
GATSBY_PUSHER_CLUSTER=us2

# =============================================================================
# SKINTWIN-AI PLATFORM INTEGRATION
# =============================================================================
# API URL for skintwin-ai platform
SKINTWIN_API_URL=https://api.skintwin.ai

# API key for platform authentication
SKINTWIN_API_KEY=your_api_key

# =============================================================================
# ERROR MONITORING (Sentry)
# =============================================================================
# Sentry DSN for error tracking (optional)
# GATSBY_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Application version for release tracking
GATSBY_APP_VERSION=2.0.0

# =============================================================================
# FEATURE FLAGS (Optional overrides)
# =============================================================================
# These can also be set via URL params: ?ff_newBookingFlow=true
# GATSBY_FF_NEW_BOOKING_FLOW=true
# GATSBY_FF_PROVIDER_SELECTION=true
# GATSBY_FF_INTAKE_FORM=true
# GATSBY_FF_REAL_TIME_AVAILABILITY=false
# GATSBY_FF_SKINTWIN_RECOMMENDATIONS=false
